<?xml version="1.0" encoding="UTF-8"?>
<project name="JatekterProject-impl" basedir="..">
    <property file="nbproject/project.properties"/>

    <!-- ============ INIT ============ -->
    <target name="-pre-init"/>
    <target name="-post-init"/>
    <target name="-init-private">
        <property file="nbproject/private/private.properties"/>
    </target>
    <target name="-init-userdir">
        <property name="user.properties.file" value="${user.home}/.netbeans/nb-ant.properties"/>
        <property file="${user.properties.file}"/>
    </target>
    <target name="-init-check">
        <fail unless="src.dir">Must set src.dir</fail>
        <fail unless="build.dir">Must set build.dir</fail>
        <fail unless="dist.dir">Must set dist.dir</fail>
        <fail unless="build.classes.dir">Must set build.classes.dir</fail>
        <fail unless="dist.jar">Must set dist.jar</fail>
        <fail unless="main.class">Must set main.class</fail>
    </target>
    <target name="-init" depends="-pre-init,-init-private,-init-userdir,-post-init,-init-check"/>

    <!-- ============ COMPILE ============ -->
    <target name="-pre-compile"/>
    <target name="-post-compile"/>
    <target name="compile" depends="-init,-pre-compile">
        <mkdir dir="${build.classes.dir}"/>
        <javac
            srcdir="${src.dir}"
            destdir="${build.classes.dir}"
            source="${javac.source}"
            target="${javac.target}"
            includeantruntime="false"
            encoding="${source.encoding}">
            <classpath path="${javac.classpath}"/>
        </javac>
        <antcall target="-post-compile"/>
    </target>

    <!-- ============ COMPILE SINGLE ============ -->
    <target name="compile-single" depends="-init">
        <fail unless="javac.includes">Must set javac.includes</fail>
        <mkdir dir="${build.classes.dir}"/>
        <javac
            srcdir="${src.dir}"
            destdir="${build.classes.dir}"
            source="${javac.source}"
            target="${javac.target}"
            includes="${javac.includes}"
            includeantruntime="false"
            encoding="${source.encoding}">
            <classpath path="${javac.classpath}"/>
        </javac>
    </target>

    <!-- ============ JAR ============ -->
    <target name="-pre-jar"/>
    <target name="-post-jar"/>
    <target name="jar" depends="compile,-pre-jar">
        <mkdir dir="${dist.dir}"/>
        <jar destfile="${dist.jar}" basedir="${build.classes.dir}">
            <manifest>
                <attribute name="Main-Class" value="${main.class}"/>
            </manifest>
        </jar>
        <antcall target="-post-jar"/>
    </target>

    <!-- ============ RUN ============ -->
    <target name="-pre-run"/>
    <target name="-post-run"/>
    <target name="run" depends="compile,-pre-run">
        <java classname="${main.class}" fork="true" failonerror="true">
            <classpath path="${run.classpath}"/>
            <jvmarg value="-Dfile.encoding=${source.encoding}"/>
        </java>
        <antcall target="-post-run"/>
    </target>

    <!-- ============ RUN SINGLE ============ -->
    <target name="run-single" depends="-init,compile-single">
        <fail unless="run.class">Must set run.class</fail>
        <java classname="${run.class}" fork="true" failonerror="true">
            <classpath path="${run.classpath}"/>
            <jvmarg value="-Dfile.encoding=${source.encoding}"/>
        </java>
    </target>

    <!-- ============ DEBUG ============ -->
    <target name="debug" depends="compile,-init">
        <java classname="${main.class}" fork="true" failonerror="true">
            <classpath path="${run.classpath}"/>
            <jvmarg value="-Xdebug"/>
            <jvmarg value="-Xrunjdwp:transport=dt_socket,address=${jpda.address},server=n,suspend=y"/>
        </java>
    </target>

    <target name="debug-single" depends="-init,compile-single">
        <fail unless="run.class">Must set run.class</fail>
        <java classname="${run.class}" fork="true" failonerror="true">
            <classpath path="${run.classpath}"/>
            <jvmarg value="-Xdebug"/>
            <jvmarg value="-Xrunjdwp:transport=dt_socket,address=${jpda.address},server=n,suspend=y"/>
        </java>
    </target>

    <!-- ============ CLEAN ============ -->
    <target name="-pre-clean"/>
    <target name="-post-clean"/>
    <target name="clean" depends="-init,-pre-clean">
        <delete dir="${build.dir}"/>
        <delete dir="${dist.dir}"/>
        <antcall target="-post-clean"/>
    </target>

    <!-- ============ JAVADOC ============ -->
    <target name="javadoc" depends="compile">
        <mkdir dir="${dist.javadoc.dir}"/>
        <javadoc destdir="${dist.javadoc.dir}" sourcepath="${src.dir}" packagenames="*">
            <classpath path="${javac.classpath}"/>
        </javadoc>
    </target>
</project>
